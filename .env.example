# Mealplan Configuration
# Copy to .env and customize

# Wake time for meal schedule (default: 7:00am)
MEALPLAN_WAKE_TIME=7:00am

# Optional: Outlook calendar integration for conflict detection
# Get your ICS URL from Outlook > Settings > Calendar > Shared calendars
# OUTLOOK_CALENDAR_ICS=https://outlook.office365.com/owa/calendar/...

# Optional: Pregnancy tracking (disabled by default)
# Set to true/1/yes to enable pregnancy features
# MEALPLAN_PREGNANCY_ENABLED=true
# MEALPLAN_PREGNANCY_DUE_DATE=2026-06-04

# Optional: Iron tracking (disabled by default)
MEALPLAN_IRON_ENABLED=true